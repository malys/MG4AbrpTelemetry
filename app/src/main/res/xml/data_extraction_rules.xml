<?xml version="1.0" encoding="utf-8"?>
<!--
   See backup_rules.xml. Applies to cloud backup and device-to-device transfer
   on API 31+: the ABRP credentials are excluded from both.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="abrp_secure_prefs.xml"/>
        <exclude domain="sharedpref" path="abrp_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="abrp_secure_prefs.xml"/>
        <exclude domain="sharedpref" path="abrp_prefs.xml"/>
    </device-transfer>
</data-extraction-rules>
